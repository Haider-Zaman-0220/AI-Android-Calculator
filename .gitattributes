# Set default behavior to automatically normalize line endings.
* text=auto

# Declare files that are truly binary and should not be modified.
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.jar binary
*.keystore binary
*.jks binary

# Ensure Gradle wrapper is executable on *nix when checked out
gradlew text eol=lf
gradlew.bat text eol=crlf

